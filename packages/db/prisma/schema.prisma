// Stky platform — single source of truth for apps/web + apps/app

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  isStaff       Boolean      @default(false)
  createdAt     DateTime     @default(now())
  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
}

// Auth.js — forward-compatible (OAuth / database sessions); staff currently uses JWT + Credentials
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Scoped automation keys (hashed at rest). Plain key is shown once at creation.
model IntegrationApiKey {
  id         String    @id @default(cuid())
  name       String?
  keyPrefix  String
  keyHash    String    @unique
  scopes     String[]  @default([])
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([keyPrefix])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  website   String?
  source    String?
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  clientId  String?
  siteId    String?

  client Client? @relation(fields: [clientId], references: [id])
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)
  deals  Deal[]
  notes  Note[]
  tasks  Task[]
}

model Deal {
  id        String   @id @default(cuid())
  value     Int?
  stage     String
  leadId    String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Task {
  id        String    @id @default(cuid())
  title     String
  dueDate   DateTime?
  completed Boolean   @default(false)
  leadId    String
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  content   String
  leadId    String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model Client {
  id                  String   @id @default(cuid())
  name                String
  primaryContactEmail String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  leads       Lead[]
  memberships Membership[]
  analytics   AnalyticsConnection[]
  sites       Site[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  clientId  String
  role      String   @default("OWNER")
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([clientId])
}

model Site {
  id           String   @id @default(cuid())
  clientId     String
  slug         String?
  customDomain String?  @unique
  subdomain    String?  @unique
  branding     Json?
  config       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pages  Page[]
  leads  Lead[]

  @@index([clientId])
}

model Page {
  id        String   @id @default(cuid())
  siteId    String
  slug      String   @default("")
  type      String   @default("MARKETING")
  seo       Json?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site     Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sections Section[]

  @@unique([siteId, slug])
  @@index([siteId])
}

model Section {
  id        String   @id @default(cuid())
  pageId    String
  order     Int
  type      String
  content   Json
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, order])
}

model AnalyticsConnection {
  id             String    @id @default(cuid())
  clientId       String
  gaPropertyId   String
  gaAccountEmail String?

  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}
