{
  "name": "stky-platform",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "db:generate": "turbo db:generate",
    "db:migrate": "pnpm --filter @stky/db exec prisma migrate dev",
    "db:push": "pnpm --filter @stky/db exec prisma db push",
    "db:studio": "pnpm --filter @stky/db exec prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18"
  }
}
