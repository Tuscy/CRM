# Shared database (run migrations from repo root: pnpm db:migrate)
DATABASE_URL="postgresql://user:pass@localhost:5432/stky"

# apps/web — multi-tenant routing
ROOT_DOMAIN="localhost"
# Optional: pin a site when using localhost without DNS
DEV_SITE_ID=""

# URLs for preview links from CRM
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WEB_URL="http://localhost:3001"

# apps/app — Auth.js (staff CRM). Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Optional legacy shared password + cookie (dev: works as before; prod: set ALLOW_LEGACY_STAFF_PASSWORD=true)
STAFF_DASHBOARD_PASSWORD=""
# Set "true" only if you must keep the legacy shared-password gate in production (not recommended)
ALLOW_LEGACY_STAFF_PASSWORD=""
# First staff user (pnpm --filter @stky/db exec prisma db seed)
STAFF_SEED_EMAIL="admin@example.com"
STAFF_SEED_PASSWORD="changeme"

# REST + automation — legacy single key (prefer Dashboard → API keys → integration keys)
CRM_API_KEY=""

# Rate limiting (middleware + magic-link abuse). Create a Redis at upstash.com — REST URL + token
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Client portal magic links (production). In development, magic link URL is logged if unset.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# CSP: set CSP_REPORT_ONLY=true to send Content-Security-Policy-Report-Only instead of enforcing
# CSP_REPORT_ONLY=""

# Outbound webhooks (e.g. n8n Webhook node URL + shared secret for HMAC)
CRM_WEBHOOK_URL=""
CRM_WEBHOOK_SECRET=""

# Self-hosted n8n REST API (server-only — used by /dashboard/automations; never NEXT_PUBLIC_)
# Base URL: HTTPS origin, no trailing slash. API key: n8n Settings → API
N8N_BASE_URL=""
N8N_API_KEY=""

# GA4 / Google OAuth (optional — see CRM README Analytics section)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URL="http://localhost:3000/api/oauth/google/callback"

# Optional: Sentry DSN for production error reporting (wire @sentry/nextjs in app if used)
# SENTRY_DSN=""
